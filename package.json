{
  "name": "local-video-tiler",
  "version": "1.0.0",
  "description": "A local desktop app to view and listen to downloaded video files in a fully customizable, tiling-window-manager style layout.",
  "main": "main.js",
  "author": "Local-Video-Tiler",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "lint": "node --check main.js && node --check preload.js && node --check src/renderer.js && node --check scripts/win-launcher.js && node --check scripts/copy-win-launcher.js",
    "pack:win": "electron-builder --win dir --x64",
    "launcher:win": "npm install --no-save pkg@5.8.1 && npx pkg scripts/win-launcher.js --targets node18-win-x64 --output \"Local Video Tiler.exe\" && node scripts/copy-win-launcher.js",
    "dist:win": "npm run pack:win && npm run launcher:win",
    "dist:win:setup": "electron-builder --win nsis --x64",
    "dist:win:portable": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.localvideotiler.app",
    "productName": "Local Video Tiler",
    "copyright": "Copyright © Local Video Tiler",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Local Video Tiler Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Local Video Tiler",
      "runAfterFinish": true,
      "uninstallDisplayName": "Local Video Tiler",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Local Video Tiler Setup.${ext}"
    },
    "portable": {
      "requestExecutionLevel": "user",
      "artifactName": "Local Video Tiler Portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
