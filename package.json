{
  "name": "local-video-tiler",
  "version": "1.0.0",
  "description": "Desktop media viewer with tiling window manager-style layouts",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node18 --outdir=dist-electron --external:electron --format=cjs",
    "build:renderer": "vite build",
    "build": "npm run build:electron && npm run build:renderer",
    "start": "npm run build && electron ."
  },
  "keywords": ["video", "tiler", "desktop", "electron"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
